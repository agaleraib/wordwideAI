{
  "name": "@finflow/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "dev:poc": "PORT=3099 bun run --hot src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "poc:uniqueness": "bun run src/benchmark/uniqueness-poc/index.ts",
    "poc:uniqueness:full": "bun run src/benchmark/uniqueness-poc/index.ts --full",
    "poc:uniqueness:all": "bun run src/benchmark/uniqueness-poc/index.ts --all --full",
    "poc:uniqueness:sequence": "bun run src/benchmark/uniqueness-poc/index.ts --sequence",
    "poc:node": "tsx src/benchmark/uniqueness-poc/index.ts",
    "poc:node:full": "tsx src/benchmark/uniqueness-poc/index.ts --full",
    "poc:node:all": "tsx src/benchmark/uniqueness-poc/index.ts --all --full",
    "poc:node:sequence": "tsx src/benchmark/uniqueness-poc/index.ts --sequence",
    "poc:analyze": "tsx src/benchmark/uniqueness-poc/analyze.ts",
    "drizzle:generate": "bunx drizzle-kit generate",
    "drizzle:migrate": "bunx drizzle-kit migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "mammoth": "^1.12.0",
    "openai": "^6.34.0",
    "postgres": "^3.4.9",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  }
}
