# Secrets
.env
.env.local

# Python (legacy finflow/ reference dir)
__pycache__/
*.pyc

# OS
.DS_Store
**/.DS_Store
Thumbs.db

# Node / Bun
node_modules/
dist/
build/
*.log
.vite/

# Benchmark + experiment outputs (not version-controlled)
