packages/api/benchmark-results-v*/
packages/api/benchmark-results/calibration-*
packages/api/benchmark-results/comparisons/
packages/api/benchmark-results/reports/
packages/api/benchmark-results/translations/
packages/api/ab-results*/
packages/api/approach3-*/
packages/api/benchmark-validation/
packages/api/cost-estimation/

# Uniqueness PoC harness output (large, generated, never tracked)
uniqueness-poc-runs/
packages/api/uniqueness-poc-state/

# Local databases / caches
finflow/data/translation_engine.db
finflow/data/cache/*.csv
*.sqlite
*.sqlite3

# Editor
.vscode/
.idea/
*.swp

# Claude harness session state
.harness-state/

# Claude Code agent worktrees — transient, recreated on /run-wave, never tracked.
# Without this, daily auto-snapshots commit them as gitlinks (mode 160000)
# and break the next /close-wave with stale-submodule status (recurring 2026-04 / -05).
.claude/worktrees/
